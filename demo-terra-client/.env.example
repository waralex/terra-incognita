# Terra server
TERRA_SERVER_URL=http://localhost:3000
TERRA_BRANCH=main

# Client server
PORT=3001

# LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=

# API keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Context window
CONTEXT_TRANSACTIONS=10
CONTEXT_ENTITIES=20

# Log LLM requests/responses to console
LOG_LLM=false
